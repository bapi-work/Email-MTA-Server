# CloudMTA Environment Configuration — Example File
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in every value before starting the stack:
#
#   cp .env.example .env
#
# .env is git-ignored so secrets are never committed. This file is safe to
# commit and acts as the canonical reference for all supported variables.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Use the internal service name "postgres" as the host when running in Docker.
DATABASE_URL=postgresql://cloudmta:CHANGE_DB_PASSWORD@postgres:5432/cloudmta_db
DB_HOST=postgres
DB_USER=cloudmta
DB_PASSWORD=CHANGE_DB_PASSWORD
DB_NAME=cloudmta_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_REDIS_PASSWORD@redis:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong secret key (required before going to production):
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_64_CHAR_HEX_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── SMTP Ports ────────────────────────────────────────────────────────────────
# These control BOTH the host-side port bindings (docker-compose) AND what the
# SMTP server listens on inside the container. Change all three together.
#
# Standard values:
#   SMTP_PORT=25        plain SMTP (some ISPs/cloud providers block port 25)
#   SMTP_TLS_PORT=587   submission with STARTTLS
#   SMTP_SSL_PORT=465   implicit TLS (SMTPS) — requires SSL certificates
#
# Alternate values (when port 25 is blocked or already in use):
#   SMTP_PORT=2525
#   SMTP_TLS_PORT=5587
#   SMTP_SSL_PORT=8465
SMTP_HOSTNAME=mail.yourdomain.com
SMTP_PORT=25
SMTP_TLS_PORT=587
SMTP_SSL_PORT=465
SMTP_TIMEOUT=30
SMTP_MAX_CONNECTIONS=1000
SMTP_QUEUE_SIZE=10000

# ── IP Settings ───────────────────────────────────────────────────────────────
IPV4_ENABLED=1
IPV6_ENABLED=1
IP_ROTATION_ENABLED=1
IP_ROTATION_INTERVAL=300

# ── API / Runtime ─────────────────────────────────────────────────────────────
# Set DEBUG=false and LOG_LEVEL=WARNING in production.
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Features ──────────────────────────────────────────────────────────────────
BULK_EMAIL_ENABLED=1
DOMAIN_MANAGEMENT_ENABLED=1
API_ACCESS_CONTROL_ENABLED=1

# ── Email Authentication ──────────────────────────────────────────────────────
SPF_ENABLED=1
DKIM_ENABLED=1
DMARC_ENABLED=1
SPF_CHECK_ENABLED=1
DKIM_SIGNING_ENABLED=1
DMARC_CHECKING_ENABLED=1

# ── Open & Click Tracking ─────────────────────────────────────────────────────
# Set TRACKING_DOMAIN to a subdomain you control (e.g. trk.yourdomain.com).
OPEN_TRACKING_ENABLED=0
CLICK_TRACKING_ENABLED=0
TRACKING_DOMAIN=

# ── IP Warmup ─────────────────────────────────────────────────────────────────
IP_WARMUP_ENABLED=1

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Add your production domain here.
# Example: CORS_ORIGINS=https://mta.yourdomain.com,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost,http://127.0.0.1:3000
